# MariaDB Configuration
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=kampbase
MARIADB_USER=user
MARIADB_PASSWORD=password

# Spring Boot Datasource Configuration
SPRING_DATASOURCE_URL=jdbc:mariadb://mariadb:3306/kampbase
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password

# Frontend API URL (used during build and for local development)
# This will be passed as a build argument to the frontend Dockerfile.
# Default value is http://backend:8080 when running in docker-compose.
# If running frontend alone, you might set it to http://localhost:8080 if backend is local.
FRONTEND_API_URL=http://backend:8080
